# ============================================================
# Smart Parking & Traffic Monitoring — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# All variables MUST start with VITE_ to be exposed to the browser.

# ── AWS Region ────────────────────────────────────────────────
VITE_AWS_REGION=ap-southeast-1

# ── Amazon Cognito ────────────────────────────────────────────
# Found in AWS Console → Cognito → User Pools → your-pool
VITE_COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Identity Pool ID (for IoT/S3 access via Cognito Identity)
VITE_COGNITO_IDENTITY_POOL_ID=ap-southeast-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Auth Lambda (admin user management) ───────────────────────
# Optional: Lambda Function URL for admin CRUD (roles, delete account)
VITE_AUTH_API_URL=https://xxxxxxxx.lambda-url.ap-southeast-1.on.aws/

# ── API Gateway ───────────────────────────────────────────────
# Base URL for your REST API (no trailing slash)
VITE_API_BASE_URL=https://ebhguaykmc.execute-api.ap-southeast-1.amazonaws.com

# ── AWS IoT Core (Realtime WebSocket) ─────────────────────────
# Found in AWS Console → IoT Core → Settings → Device data endpoint
VITE_IOT_ENDPOINT=xxxxxxxxxxxxxxx-ats.iot.ap-southeast-1.amazonaws.com
# MQTT topic prefix for parking events
VITE_IOT_TOPIC_PREFIX=smart-parking/

# ── Amazon Bedrock (AI Assistant) ─────────────────────────────
# Model ID used for the AI chat (via API Gateway proxy)
VITE_BEDROCK_MODEL_ID=meta.llama3-8b-instruct-v1:0
# API Gateway endpoint that proxies Bedrock
VITE_AI_API_URL=https://xxxxxxxxxx.execute-api.ap-southeast-1.amazonaws.com/prod/ai

# ── App Config ────────────────────────────────────────────────
VITE_APP_NAME=Smart Parking System
VITE_APP_VERSION=1.0.0
# Set to 'true' to enable mock data (no real AWS calls)
VITE_USE_MOCK_DATA=false
